rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is user authenticated
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // users/{uid}
    match /users/{uid} {
      allow read: if isOwner(uid);
      // Allow create/update of the user root doc (profile + timestamps).
      // Clients call this on first launch to ensure the parent path exists.
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid;
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);

      // users/{uid}/disputes/{disputeId}
      // `read` covers both get + list (collection queries on Home).
      match /disputes/{disputeId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.uid == uid;
        allow update: if isOwner(uid)
                      && resource.data.uid == uid
                      && request.resource.data.uid == uid;
        allow delete: if isOwner(uid);
      }

      // users/{uid}/reminders/{reminderId}
      match /reminders/{reminderId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.uid == uid;
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
