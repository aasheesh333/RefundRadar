<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash background. Uses @color/app_bg which resolves per
     configuration (light #F5F5F5 / dark #121212) so the splash matches
     the app surface in both themes — no white→app or black→app flash. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/app_bg" />

